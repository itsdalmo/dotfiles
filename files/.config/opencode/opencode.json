{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "permission": {
    "external_directory": {
      "*": "ask",
      "/tmp/**": "allow"
    }
  },
  "formatter": {
    "biome": {
      "disabled": true
    },
    "oxfmt": {
      "disabled": true
    },
    "prettier": {
      "command": [
        "prettier",
        "--write",
        "--print-width",
        "120",
        "--prose-wrap",
        "never",
        "$FILE"
      ],
      "extensions": [
        ".json",
        ".jsonc",
        ".md",
        ".yaml",
        ".yml"
      ]
    },
    "gofmt": {
      "command": [
        "gofumpt",
        "-w",
        "$FILE"
      ],
      "extensions": [
        ".go"
      ]
    },
    "alloy": {
      "command": [
        "alloy",
        "fmt",
        "$FILE"
      ],
      "extensions": [
        ".alloy"
      ]
    },
    "terraform": {
      "command": [
        "terraform",
        "fmt",
        "$FILE"
      ],
      "extensions": [
        ".hcl",
        ".tf",
        ".tfvars"
      ]
    },
    "jsonnetfmt": {
      "command": [
        "jsonnetfmt",
        "-i",
        "$FILE"
      ],
      "extensions": [
        ".jsonnet",
        ".libsonnet"
      ]
    },
    "stylua": {
      "command": [
        "stylua",
        "$FILE"
      ],
      "extensions": [
        ".lua"
      ]
    },
    "shfmt": {
      "command": [
        "shfmt",
        "-w",
        "$FILE"
      ],
      "extensions": [
        ".sh",
        ".bash"
      ]
    }
  }
}
